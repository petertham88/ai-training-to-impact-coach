# Supabase — get from your project dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side only — NEVER expose to browser.
# Required for the trainer /admin + manager views once per-user RLS
# (supabase/migrations/0002_auth_rls.sql) is applied, so those cross-user reads
# can bypass owner RLS. Until RLS is locked down the app falls back to the anon
# key and still works.
SUPABASE_SERVICE_ROLE_KEY=

# Trainer /admin gate (app-layer). Defaults to trainer@demo.com / impact2025
# if unset. Set these in production to your real trainer credentials.
TRAINER_EMAIL=
TRAINER_PASSCODE=

# ── Stripe ──────────────────────────────────────────────────────────────────
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_

# Webhook secret — from Stripe dashboard → Webhooks → your endpoint
# For local dev: stripe listen --forward-to localhost:3000/api/stripe/webhooks
STRIPE_WEBHOOK_SECRET=whsec_

# Your price IDs from Stripe dashboard → Products
NEXT_PUBLIC_STRIPE_PRICE_MONTHLY=price_
NEXT_PUBLIC_STRIPE_PRICE_YEARLY=price_

# ── Stripe Connect (set by Vibe Launchpad when provisioned via platform) ────
# Leave blank if running standalone with your own Stripe account
STRIPE_CONNECT_ACCOUNT_ID=
STRIPE_PLATFORM_FEE_PERCENT=

# ── App URL (used for redirect URLs) ────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
